# Database Credentials
POSTGRES_USER=vendora_user
POSTGRES_PASSWORD=vendora_password
POSTGRES_DB=vendora_db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Prisma Connection String
DATABASE_URL="postgresql://vendora_user:vendora_password@127.0.0.1:5433/vendora_db?schema=public"

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT Security
JWT_SECRET=your_super_secret_key_here
