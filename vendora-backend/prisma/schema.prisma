// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  SELLER
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_APPROVAL
  OPEN
  TERMINATED
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  MANAGER
}

enum SubscriptionType {
  FIXED
  COMMISSION
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
}

enum PaymentMethod {
  COD
  IBURAQ
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AdTier {
  PREMIUM
  STANDARD
}

enum RequestType {
  SELLER_REGISTRATION
  PRODUCT_APPROVAL
  CATALOG_CHANGE
  REVIEW_REMOVAL
  RETURN_REQUEST
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  RESOLVED
}

model MarketplaceRequest {
  id          String        @id @default(uuid())
  type        RequestType
  status      RequestStatus @default(PENDING)
  submitterId String
  storeId     String?
  data        Json
  adminNotes  String?
  feedback    String?
  priority    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  submitter User   @relation(fields: [submitterId], references: [id])
  store     Store? @relation(fields: [storeId], references: [id])
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  email     String?  @unique
  name      String?
  firstName String?
  lastName  String?
  role      UserRole @default(CUSTOMER)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders         Order[]
  storeMembers   StoreMember[]
  addresses      Address[]
  groups         CustomerGroup[] @relation("UserToGroup")
  organizationId String?
  organization   Organization?        @relation(fields: [organizationId], references: [id])
  submittedRequests MarketplaceRequest[]
}

model Address {
  id                String  @id @default(uuid())
  userId            String
  firstName         String?
  lastName          String?
  company           String?
  address1          String
  address2          String?
  city              String
  province          String?
  postalCode        String?
  countryCode       String
  phone             String?
  isDefaultShipping Boolean @default(false)
  isDefaultBilling  Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
}

model CustomerGroup {
  id       String @id @default(uuid())
  name     String @unique
  metadata Json?
  users    User[] @relation("UserToGroup")
}

model Organization {
  id       String @id @default(uuid())
  name     String
  metadata Json?
  members  User[]
}

model Store {
  id              String      @id @default(uuid())
  name            String
  handle          String      @unique
  description     String?     @db.Text
  status          StoreStatus @default(INACTIVE)
  iburaqIban      String?
  contactPhone    String?
  businessAddress String?
  taxId           String?
  logoUrl         String?
  bannerUrl       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  products      Product[]
  subOrders     SubOrder[]
  shippingRates ShippingRate[]
  members       StoreMember[]
  subscription  StoreSubscription?
  onboarding    StoreOnboarding?
  invites       MemberInvite[]
  requests      MarketplaceRequest[]
}

model StoreOnboarding {
  id                String  @id @default(uuid())
  storeId           String  @unique
  storeInformation  Boolean @default(false)
  stripeConnection  Boolean @default(false)
  locationsShipping Boolean @default(false)
  products          Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id])
}

model MemberInvite {
  id        String     @id @default(uuid())
  email     String
  role      MemberRole
  token     String     @unique
  expiresAt DateTime
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  invitedBy String
  createdAt DateTime   @default(now())
}

model StoreMember {
  id      String     @id @default(uuid())
  userId  String
  storeId String
  role    MemberRole @default(OWNER)

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
}

model Product {
  id          String   @id @default(uuid())
  storeId     String
  title       Json
  description Json?
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store        @relation(fields: [storeId], references: [id])
  orderItems  OrderItem[]
  adSchedules AdSchedule[]
}

model AdSchedule {
  id           String   @id @default(uuid())
  productId    String
  tier         AdTier   @default(STANDARD)
  startDate    DateTime
  endDate      DateTime
  excludedDays Int[] // 0-6 for Sun-Sat
  pricePaid    Float

  product Product @relation(fields: [productId], references: [id])
}

model SubscriptionPlan {
  id              String           @id @default(uuid())
  name            String
  type            SubscriptionType
  monthlyPrice    Float
  commissionRate  Float            @default(0)
  monthsFree      Int              @default(0)

  subscriptions StoreSubscription[]
}

model StoreSubscription {
  id            String             @id @default(uuid())
  storeId       String             @unique
  planId        String
  status        SubscriptionStatus @default(ACTIVE)
  endDate       DateTime
  isGracePeriod Boolean            @default(false)

  store Store            @relation(fields: [storeId], references: [id])
  plan  SubscriptionPlan @relation(fields: [planId], references: [id])
}

model ShippingZone {
  id   String @id @default(uuid())
  name String @unique

  shippingRates ShippingRate[]
  orders        Order[]
}

model ShippingRate {
  id      String @id @default(uuid())
  storeId String
  zoneId  String
  price   Float

  store Store        @relation(fields: [storeId], references: [id])
  zone  ShippingZone @relation(fields: [zoneId], references: [id])

  @@unique([storeId, zoneId])
}

model Order {
  id             String        @id @default(uuid())
  customerId     String
  shippingZoneId String
  paymentMethod  PaymentMethod
  iburaqProofUrl String?
  totalPrice     Float
  status         OrderStatus   @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer User         @relation(fields: [customerId], references: [id])
  zone     ShippingZone @relation(fields: [shippingZoneId], references: [id])
  subOrders SubOrder[]
}

model SubOrder {
  id                 String      @id @default(uuid())
  orderId            String
  storeId            String
  status             OrderStatus @default(PENDING)
  shippingFeeCharged Float
  subTotal           Float
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  store Store @relation(fields: [storeId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id              String @id @default(uuid())
  subOrderId      String
  productId       String
  quantity        Int
  priceAtPurchase Float

  subOrder SubOrder @relation(fields: [subOrderId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}
model AdPricingConfig {
  tier           AdTier @id
  basePrice      Float
  peakMultiplier Float
  peakDays       Int[] // 0-6 for Sun-Sat
}

model PeakPriceEvent {
  id         String   @id @default(uuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  multiplier Float
}
